# MCP 邮件服务器环境配置
# 请复制此文件为 .env 并填入您的实际配置

# IMAP 配置（QQ 邮箱）
IMAP_HOST=imap.qq.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=your-email@qq.com
IMAP_PASS=your-16-digit-authorization-code

# SMTP 配置（可选，用于发送邮件）
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@qq.com
SMTP_PASS=your-16-digit-authorization-code

# 默认发件人信息（可选）
DEFAULT_FROM_NAME=Your Name
DEFAULT_FROM_EMAIL=your-email@qq.com
